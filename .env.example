# Upstash Redis (https://upstash.com) — required for stat block CRUD in production.
# Use a separate database or set REDIS_KEY_PREFIX for Vercel Preview vs Production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: prefix all keys (e.g. "preview:" for preview deployments)
# REDIS_KEY_PREFIX=
