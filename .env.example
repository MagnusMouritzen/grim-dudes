# Upstash Redis (https://upstash.com) — required for stat block CRUD in production.
# Use a separate database or set REDIS_KEY_PREFIX for Vercel Preview vs Production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: prefix all keys (e.g. "preview:" for preview deployments)
# REDIS_KEY_PREFIX=

# Optional: canonical site URL for robots.txt / sitemap (production)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Session auth (optional). When AUTH_SECRET and a password are set, mutating routes
# require signing in at /login unless AUTH_DISABLED=1 (local open writes).
# AUTH_SECRET=          # long random string, e.g. openssl rand -base64 32
# AUTH_PASSWORD=        # plain password (dev); prefer AUTH_PASSWORD_HASH in production
# AUTH_PASSWORD_HASH=   # bcrypt hash of password (production)
# AUTH_USER=            # optional fixed username; if set, login must match
# AUTH_DISABLED=1       # skip auth checks (local only)

# Optional: if set, manual GET /api/admin/cleanup-orphans requires Authorization: Bearer <CRON_SECRET>
# (Vercel Cron still uses x-vercel-cron and does not need this.)
# CRON_SECRET=

# Optional rate limits (when Upstash is configured)
# RATE_LIMIT_WRITES_PER_MIN=30
# RATE_LIMIT_LOGIN_PER_MIN=15
