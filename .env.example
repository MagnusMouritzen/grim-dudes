# Upstash Redis (https://upstash.com) — required for stat block CRUD in production.
# Use a separate database or set REDIS_KEY_PREFIX for Vercel Preview vs Production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: prefix all keys (e.g. "preview:" for preview deployments)
# REDIS_KEY_PREFIX=

# Optional: canonical site URL for robots.txt / sitemap (production)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Session auth (optional). When AUTH_SECRET and a password are set, mutating routes
# require signing in at /login unless AUTH_DISABLED=1 (local open writes).
# AUTH_SECRET=          # long random string, e.g. openssl rand -base64 32
# AUTH_PASSWORD=        # plain password (dev); prefer AUTH_PASSWORD_HASH in production
# AUTH_PASSWORD_HASH=   # bcrypt hash of password (use instead of plain in production)
# AUTH_USER=            # optional fixed username; if set, login must match
# AUTH_DISABLED=1       # skip auth checks (local only)

# In production, when Upstash is set but AUTH_SECRET+password are not, writes return
# 503 unless you set the dangerous opt-out (demos / internal only):
# ALLOW_UNAUTHENTICATED_WRITES=1

# Cron cleanup: in production, CRON_SECRET is required. Vercel injects
# Authorization: Bearer <CRON_SECRET> for scheduled crons when this is set in the project.
# For local non-production, x-vercel-cron: 1 is accepted if CRON_SECRET is unset.
# CRON_SECRET=

# Optional: in production, GET /api/healthz?verbose=1 with Authorization: Bearer <HEALTHZ_TOKEN>
# returns details (auth flags, region, env). Without this token, /api/healthz only returns ok + redis.
# HEALTHZ_TOKEN=

# Optional rate limits. Uses Upstash when set; otherwise an in-process limiter (per instance).
# RATE_LIMIT_WRITES_PER_MIN=30
# RATE_LIMIT_LOGIN_PER_MIN=15
